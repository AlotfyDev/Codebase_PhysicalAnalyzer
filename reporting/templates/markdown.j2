# .github/workflows/arch-check.yml
- name: Check Architectural Health
  run: |
    SCORE=$(python -c "import json; d=json.load(open('graphify-out/graph.json')); print(d['metadata']['architectural_report']['health_score'])")
    if (( $(echo "$SCORE < 70" | bc -l) )); then
      echo "❌ Architectural Health Score ($SCORE) is below threshold (70)."
      exit 1
    else
      echo "✅ Architecture is healthy ($SCORE/100)."
    fi



