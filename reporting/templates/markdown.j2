# report_generator.py | Contract: Dynamic Report Generation via Jinja2
from __future__ import annotations
import os
from pathlib import Path
from typing import Any, Dict, List, Optional
from jinja2 import Template

# ---------------------------------------------------------------------------
# قالب Jinja2 مُضمَّن (Embedded Template)
# ---------------------------------------------------------------------------
MARKDOWN_TEMPLATE = """
# 🏗️ Architectural Insights Report
**Generated:** `{{ metadata.generated_at }}` | **Project:** `{{ metadata.project_root | basename }}` | **Health Score:** {{ metadata.health_score | health_badge }} (`{{ metadata.health_score }}`/100)

## 📊 Executive Summary
| Metric | Value | Status |
|--------|-------|--------|
{% for m in summary_metrics %}
| {{ m.name }} | `{{ m.value }}` | {{ m.status | status_badge }} |
{% endfor %}

{% if critical_insights %}
## 🔴 Critical Findings ({{ critical_insights | length }})
{% for i in critical_insights %}
### {{ i.insight_id }}: {{ i.title }}
**Category:** `{{ i.category }}` | **Evidence Count:** {{ i.evidence | length }}
{{ i.description }}

**Traceability Path:** `{{ i.traceability_matrix[0].evidence_path if i.traceability_matrix else "N/A" }}`
{% endfor %}
{% endif %}

{% if warning_insights %}
## 🟡 Warnings & Technical Debt ({{ warning_insights | length }})
{% for i in warning_insights %}
### {{ i.insight_id }}: {{ i.title }}
**Category:** `{{ i.category }}` | **Recommendation:** {{ i.recommendation }}
{% endfor %}
{% endif %}

{% if info_insights %}
## 🟢 Positive Patterns & Strengths
{% for i in info_insights %}
- **{{ i.title }}**: {{ i.description }}
{% endfor %}
{% endif %}

## 📐 Traceability & Validity Matrix
| ID | Category | Metric | Actual | Threshold | Status | Evidence Path |
|----|----------|--------|--------|-----------|--------|---------------|
{% for i in all_insights %}
{% for rec in i.traceability_matrix %}
| `{{ i.insight_id }}` | `{{ i.category }}` | `{{ rec.metric_name }}` | `{{ rec.actual_value }}` | `{{ rec.threshold }}` | {{ rec.status | status_badge }} | `{{ rec.evidence_path }}` |
{% endfor %}
{% endfor %}

## 🛠️ Recommended Actions
{% for a in recommendations %}
{{ loop.index }}. **[P{{ a.priority }}]** {{ a.action }}
{% endfor %}

---
🤖 *Generated by Graphify Physical Analyzer v{{ version }} | Template: Jinja2 Dynamic Engine*
""".strip()


class ReportGenerator:
    """
    [Contract: Dynamic Markdown Generation]
    يُولّد تقارير Markdown ديناميكية من بيانات الـ Insights باستخدام Jinja2.
    يدعم الفلاتر المخصصة، التجميع الشرطي، والتكيف التلقائي مع هيكل البيانات.
    """
    
    def __init__(self, template_str: Optional[str] = None, version: str = "1.0.0"):
        self.template = Template(template_str or MARKDOWN_TEMPLATE)
        self.version = version
        self._register_filters()

    def _register_filters(self):
        self.template.environment.filters["status_badge"] = self._status_badge
        self.template.environment.filters["health_badge"] = self._health_badge
        self.template.environment.filters["basename"] = lambda p: Path(p).name if p else "N/A"
        self.template.environment.filters["truncate"] = lambda lst, n=5: lst[:n]

    @staticmethod
    def _status_badge(status: str) -> str:
        status = str(status).upper()
        return {"PASS": "🟢 PASS", "WARN": "🟡 WARN", "FAIL": "🔴 FAIL", "INFO": "🔵 INFO"}.get(status, f"⚪ {status}")

    @staticmethod
    def _health_badge(score: float) -> str:
        if score >= 90: return f"🟢 Excellent ({score:.0f})"
        if score >= 70: return f"🟡 Good ({score:.0f})"
        if score >= 50: return f"🟠 Needs Work ({score:.0f})"
        return f"🔴 Critical ({score:.0f})"

    def _build_context(self, report_data: Dict[str, Any]) -> Dict[str, Any]:
        insights = report_data.get("insights", [])
        metrics = report_data.get("metadata", {})
        recommendations = report_data.get("recommendations", [])

        # تجميع الملخص التنفيذي ديناميكيًا من البيانات الخام
        summary_metrics = [
            {"name": "Health Score", "value": metrics.get("health_score", "N/A"), "status": "INFO"},
            {"name": "Critical Issues", "value": sum(1 for i in insights if i.get("severity") == "critical"), "status": "FAIL" if any(i.get("severity")=="critical" for i in insights) else "PASS"},
            {"name": "Warnings", "value": sum(1 for i in insights if i.get("severity") == "warning"), "status": "WARN" if any(i.get("severity")=="warning" for i in insights) else "PASS"},
        ]

        return {
            "metadata": metrics,
            "summary_metrics": summary_metrics,
            "critical_insights": [i for i in insights if i.get("severity") == "critical"],
            "warning_insights": [i for i in insights if i.get("severity") == "warning"],
            "info_insights": [i for i in insights if i.get("severity") == "info"],
            "all_insights": insights,
            "recommendations": recommendations,
            "version": self.version
        }

    def render(self, report_data: Dict[str, Any], output_path: Optional[str | Path] = None) -> str:
        context = self._build_context(report_data)
        rendered_md = self.template.render(**context)
        
        if output_path:
            Path(output_path).write_text(rendered_md, encoding="utf-8")
        return rendered_md

# واجهة سهلة الاستخدام
def generate_dynamic_report(report_data: Dict[str, Any], output_dir: str | Path = ".", filename: str = "architectural_report.md") -> str:
    gen = ReportGenerator()
    out_path = Path(output_dir) / filename
    return gen.render(report_data, out_path)



