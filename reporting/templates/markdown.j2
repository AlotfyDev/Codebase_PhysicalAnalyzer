if args.codebase_report:
    from graphify.physical_analyzer.insight_extractor import InsightExtractor
    from graphify.physical_analyzer.report_generator import generate_dynamic_report

    extractor = InsightExtractor()
    insights_data = extractor.extract(extractions)  # JSON-ready dict
    
    # توليد التقرير الديناميكي
    generate_dynamic_report(insights_data, output_dir=args.output)
    
    # حقن الملخص في graph.json نفسه
    extractions["metadata"]["architectural_report"] = {
        "health_score": insights_data["metadata"]["health_score"],
        "critical_count": len([i for i in insights_data["insights"] if i["severity"]=="critical"]),
        "warnings_count": len([i for i in insights_data["insights"] if i["severity"]=="warning"]),
        "generated_at": insights_data["metadata"]["generated_at"]
    }


